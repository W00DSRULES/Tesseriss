# Copy to .env.local and fill in. .env.local is gitignored.

# Apple Developer Team ID (10-char alphanumeric, find in https://developer.apple.com/account → Membership)
TEAM_ID=

# Optional: override the bundle id baked into project.yml (de.maindtec.Tesseriss).
# Must match the App Store Connect app record's bundle id.
# BUNDLE_ID=com.example.tesseriss

# Optional: app version + build number. Build number must increase on every TestFlight upload.
# MARKETING_VERSION=0.1.0
# BUILD_NUMBER=1

# App Store Connect API key
# Create at: https://appstoreconnect.apple.com → Users and Access → Integrations → App Store Connect API
ASC_API_KEY_ID=
ASC_API_ISSUER_ID=
ASC_API_KEY_PATH=./private_keys/AuthKey_XXXXXXXXXX.p8
